# Copy to docker-compose.override.yml and customize
# This file is NOT gitignored - it's a template
services:
  convert-service:
    build:
      context: .
      dockerfile: Dockerfile
      args:
        ENABLE_PGO: "true"
        ARCH_FLAGS: "-march=native"
    image: archive-video-av1:local
    volumes:
      - /your/local/path:/videos
      - app-data:/app/data
    environment:
      AUDIO_TRACK_MODE: preferred
      SUBTITLE_TRACK_MODE: preferred
      PREFERRED_AUDIO_LANGUAGES: ger,deu,de,eng,en
      PREFERRED_SUBTITLE_LANGUAGES: ger,deu,de,eng,en
      # DISTRIBUTED_ENABLED: "true"
      # DISTRIBUTED_NODE_ID: node-a
      # DISTRIBUTED_NODE_NAME: Node A
      # DISTRIBUTED_PUBLIC_URL: http://192.168.1.10:8000
      # DISTRIBUTED_LEADER_URL: http://192.168.1.10:8000
      # DISTRIBUTED_PEERS: http://192.168.1.11:8000,http://192.168.1.12:8000
    # You can also override ports, environment, etc.
    # ports:
    #   - "8001:8000"
    #   - "9988:9988/udp"

volumes:
  app-data:
